{
  "name": "GymBro's",
  "short_name": "GymBro's",
  "description": "PWA estatica per sincronitzar catalogs publics de gimnàs al dispositiu i rebre recomanacions, rutines i historic local.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#d9d5cf",
